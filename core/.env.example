# ── 地端 SOP 助理：設定範例 ──
# 複製成 .env 後填值。所有值都是「佔位符」，請換成你自己的。
# ⚠️ 真實密碼/金鑰絕不可 commit。.env 與 .review-password 都應在 .gitignore。

# ── 服務埠 / 綁定 ──
PORT=<PORT>                      # backend 對 LAN 開的埠，例 3000
HOST=0.0.0.0                     # 0.0.0.0=LAN 可達；只要本機就 127.0.0.1

# 對外網域（給 internalOnly 判斷「外網」用）。命中這些 hostname 的請求一律擋寫入/審核。
PUBLIC_HOSTNAMES=<PUBLIC_HOSTNAME>   # 例 sop.example.com（沒有對外就留空）

# ── 對話 LLM（OpenAI 相容服務）──
CHAT_URL=http://127.0.0.1:<CHAT_PORT>/v1
CHAT_API_KEY=<CHAT_API_KEY>          # 本機服務的 key（仍存 env，別寫死）
CHAT_MODEL=<CHAT_MODEL_NAME>         # 例 your-local-chat-model
CHAT_TEMPERATURE=0.3
CHAT_MAX_TOKENS=2048
CHAT_TIMEOUT_MS=120000               # 要涵蓋冷載入
CHAT_WARM_INTERVAL_MS=240000         # 每 4 分保溫一次；0=關閉

# ── Embedding（Ollama）──
OLLAMA_URL=http://127.0.0.1:11434
EMBED_MODEL=<EMBED_MODEL_NAME>       # 多語、中文強的 embedding 模型；維度自動偵測
EMBED_KEEP_ALIVE=30m

# ── Reranker（本機 cross-encoder 小服務）──
RERANKER_URL=http://127.0.0.1:<RERANK_PORT>
RERANKER_MODEL=<RERANKER_MODEL_ID>   # 例 BAAI/bge-reranker-v2-m3
USE_RERANKER=true                    # false=完全停用，退回純 cosine

# ── RAG 門檻（針對「你的 embedding + reranker 分數分佈」校準，換模型要重調）──
SIMILARITY_THRESHOLD=0.5             # reranker 掛掉時的純 cosine 門檻
RERANK_CANDIDATES=20                 # 送進 reranker 的候選數
RERANK_THRESHOLD=0.1                 # 主訊號門檻：rerank ≥ 此值才算命中
COSINE_GATE=0.60                     # 整題 fallback：reranker 都不達標時改看 cosine
MAX_CONTEXT_CHARS=2000               # 餵給對話模型的 context 字數上限
TOP_N_CHUNKS=5                       # 最多取幾個命中 chunk
TOP_N_DOCS=5                         # 最多列幾份來源文件
EMBED_INPUT_CHARS=3000               # 單一 chunk 餵給 embedding 的字數上限
HISTORY_TURNS=6                      # 網頁問答帶入的最近對話輪數
LINE_FOLLOWUP_TURNS=2                # LINE 追問時帶入的輪數
LINE_IDLE_MS=1800000                 # LINE 閒置逾此(30分)視為新對話

# ── 審核密碼（二擇一；都不設 → 所有寫入/審核 API 一律 403）──
# 方式一：環境變數（優先）
REVIEW_PASSWORD=<REVIEW_PASSWORD>
# 方式二：放在 gitignored 的 .review-password 檔（程式會讀），此時可不設上面這行
